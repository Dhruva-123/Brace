# ─────────────────────────────────────────────
#  BRACE — Environment Configuration
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Session secret (generate a long random string)
SESSION_SECRET=change_me_to_something_long_and_random_like_brace2024secretkey

# Server port
PORT=3000

# ─────────────────────────────────────────────
#  FREE API KEYS — Where to get them
# ─────────────────────────────────────────────

# 1. EXCHANGE RATES (Free, no key needed for basic)
#    https://open.er-api.com/v6/latest/USD  ← works without key
#    For higher limits: https://www.exchangerate-api.com/ (free tier: 1500 req/month)
EXCHANGE_RATE_API_KEY=your_key_here

# 2. REST COUNTRIES (Free, no key needed)
#    https://restcountries.com — no API key required
#    Used for: country data, region, currency, languages

# 3. HUGGING FACE — AI/ML Models (Free inference API)
#    Sign up: https://huggingface.co/join
#    Get token: https://huggingface.co/settings/tokens
#    FREE MODELS TO USE:
#      - Trade risk classification: "distilbert-base-uncased-finetuned-sst-2-english"
#      - Text summarization: "facebook/bart-large-cnn"  
#      - Sentiment/trust scoring: "cardiffnlp/twitter-roberta-base-sentiment"
#      - Document generation text: "mistralai/Mistral-7B-Instruct-v0.2" (slow free tier)
HUGGING_FACE_API_KEY=hf_your_token_here

# 4. OPEN EXCHANGE RATES (Free tier: 1000 req/month)
#    https://openexchangerates.org/signup/free
OPEN_EXCHANGE_APP_ID=your_app_id_here

# 5. WORLD BANK API (Completely free, no key needed)
#    https://api.worldbank.org — tariff data, trade stats
#    Used for: country economic indicators

# 6. COMTRADE (UN Comtrade — Free, no key for basic)
#    https://comtradeapi.un.org — HS codes, trade flows

# ─────────────────────────────────────────────
#  DATABASE
# ─────────────────────────────────────────────
# SQLite is used locally — no setup needed
DB_PATH=./brace.db
